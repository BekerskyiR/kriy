---
import Layout from "../layouts/Layout.astro";
import { getFeaturedPlan } from "../lib/plans";
import { getBrands, getTotalInStock } from "../lib/catalog";
import { getLocale, useT } from "../lib/i18n";

const locale = getLocale(Astro.cookies);
const t = useT(locale);

const [plan, brands, total] = await Promise.all([
  getFeaturedPlan(),
  getBrands(),
  getTotalInStock(),
]);

// total outbound clicks the showcase has already sent brands — the core pitch
const totalClicks = brands.reduce((sum, b) => sum + (b.outboundClicks ?? 0), 0);
const nf = new Intl.NumberFormat(locale === "en" ? "en-US" : "uk-UA");

// plan name/perks come from the dictionary (CMS plan is Ukrainian-only);
// only the id and the numeric price come from the plan itself
const priceAmount = plan?.priceText.split(" / ")[0] ?? "";
const perks: Array<"brands.perk1" | "brands.perk2" | "brands.perk3"> = [
  "brands.perk1",
  "brands.perk2",
  "brands.perk3",
];
---

<Layout
  nav="brands"
  title={locale === "en" ? "For brands — KRIY" : "Для брендів — КРІЙ"}
  description={locale === "en"
    ? "List your brand in the KRIY showcase and get targeted shoppers straight to your site."
    : "Розмістіть свій бренд у вітрині КРІЙ і отримуйте переходи цільових покупців напряму на ваш сайт."}
>
  <section class="section">
    <div class="container pitch">
      <span class="eyebrow">{t("brands.eyebrow")}</span>
      <h1>{t("brands.title")}</h1>
      <p class="pitch__lede">{t("brands.lede")}</p>

      <div class="hero__meta">
        <span><strong>{nf.format(total)}</strong> {t("brands.mInCatalog")}</span>
        <span><strong>{brands.length}</strong> {t("brands.mBrands")}</span>
        <span><strong>{nf.format(totalClicks)}</strong> {t("brands.mClicks")}</span>
      </div>

      <ol class="steps">
        <li><span>{t("brands.step1")}</span></li>
        <li><span>{t("brands.step2")}</span></li>
        <li>
          <span>{t("brands.step3a")} <strong>featured</strong> {t("brands.step3b")}</span>
        </li>
      </ol>

      {
        plan ? (
          <div class="plan-card">
            <span class="badge-featured">featured</span>
            <h3>{t("brands.planName")}</h3>
            <div class="price">
              {priceAmount}
              <small>{t("brands.perMonth")}</small>
            </div>
            <ul>
              {perks.map((p) => (
                <li>{t(p)}</li>
              ))}
            </ul>
            <a class="btn btn--primary" href={`/subscribe?planId=${plan._id}`}>
              {t("brands.cta")}
            </a>
          </div>
        ) : (
          <div class="empty-state" style="margin-top:2.5rem">
            <h3>{t("brands.planUnavailable")}</h3>
            <p>{t("brands.planUnavailableBody")}</p>
          </div>
        )
      }
    </div>
  </section>
</Layout>
