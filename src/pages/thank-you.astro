---
import Layout from "../layouts/Layout.astro";
---

<Layout
  nav="brands"
  title="Дякуємо — КРІЙ"
  description="Оплату отримано. Ваш бренд стає featured у вітрині КРІЙ."
>
  <section class="section">
    <div class="container pitch">
      <span class="eyebrow">Оплата отримана</span>
      <h1>Вітаємо у вітрині ✦</h1>
      <p class="pitch__lede">
        Дякуємо! Ваш бренд стає <strong>featured</strong> — з'явиться у блоці
        «Обрані бренди» на головній, а товари піднімуться вгору в категоріях.
        Зміни застосуються протягом кількох хвилин після синхронізації.
      </p>
      <div style="margin-top:2rem; display:flex; gap:1rem; flex-wrap:wrap;">
        <a class="btn btn--primary" href="/">До каталогу →</a>
        <a class="btn btn--ghost" href="/for-brands">Назад до тарифу</a>
      </div>
    </div>
  </section>
</Layout>
