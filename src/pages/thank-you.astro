---
import Layout from "../layouts/Layout.astro";
import { getLocale, useT } from "../lib/i18n";

const locale = getLocale(Astro.cookies);
const t = useT(locale);
---

<Layout
  nav="brands"
  title={locale === "en" ? "Thank you — KRIY" : "Дякуємо — КРІЙ"}
  description={locale === "en"
    ? "Payment received. Your brand is now featured in the KRIY showcase."
    : "Оплату отримано. Ваш бренд стає featured у вітрині КРІЙ."}
>
  <section class="section">
    <div class="container pitch">
      <span class="eyebrow">{t("thanks.eyebrow")}</span>
      <h1>{t("thanks.title")}</h1>
      <p class="pitch__lede">{t("thanks.lede")}</p>
      <div style="margin-top:2rem; display:flex; gap:1rem; flex-wrap:wrap;">
        <a class="btn btn--primary" href="/">{t("thanks.toCatalog")}</a>
        <a class="btn btn--ghost" href="/for-brands">{t("thanks.backToPlan")}</a>
      </div>
    </div>
  </section>
</Layout>
