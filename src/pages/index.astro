---
import Layout from "../layouts/Layout.astro";
import {
  getCategories,
  getCategoryCounts,
  getBrands,
  getTotalInStock,
  catName,
  brandDesc,
  type GenderFilter,
} from "../lib/catalog";
import { getLocale, useT } from "../lib/i18n";

const locale = getLocale(Astro.cookies);
const t = useT(locale);

const gParam = Astro.url.searchParams.get("g");
const gender: GenderFilter = gParam === "men" || gParam === "women" ? gParam : "all";

const [categories, counts, featured, allBrands, total] = await Promise.all([
  getCategories(),
  getCategoryCounts(gender),
  getBrands({ featuredOnly: true }),
  getBrands(),
  getTotalInStock(gender),
]);

// show only top-level categories that actually have products
const topCategories = categories
  .filter((c) => !c.parentSlug)
  .map((c) => ({ ...c, count: counts[c.slug] ?? 0 }))
  .filter((c) => c.count > 0);

// carry the active gender into category links so the filter isn't lost
const catHref = (slug: string) => (gender === "all" ? `/c/${slug}` : `/c/${slug}?g=${gender}`);

const nf = new Intl.NumberFormat(locale === "en" ? "en-US" : "uk-UA");
---

<Layout nav="catalog" gender={gender}>
  <section class="hero">
    <div class="container">
      <h1>{t("home.heroA")} <span class="ye">{t("home.heroAccent")}</span>.</h1>
      <p class="hero__lede">{t("home.lede")}</p>
      <div class="hero__meta">
        <span><strong>{nf.format(total)}</strong> {t("home.inStock")}</span>
        <span><strong>{allBrands.length}</strong> {t("home.brands")}</span>
        <span><strong>{topCategories.length}</strong> {t("home.categories")}</span>
      </div>
    </div>
  </section>

  <hr class="stitch stitch--sew" />

  {
    featured.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="section__head">
            <h2>{t("home.featured")}</h2>
            <span class="count">{t("home.recommended")}</span>
          </div>
          <ul class="brand-list">
            {featured.map((b) => (
              <li class="brand-card brand-card--featured">
                <span class="brand-card__name">
                  {b.name}
                  <span class="badge-featured">featured</span>
                </span>
                <span class="brand-card__desc">{brandDesc(b, locale)}</span>
                <a
                  class="brand-card__link"
                  href={`/out?b=${encodeURIComponent(b.slug)}&u=${encodeURIComponent(b.siteUrl)}`}
                  target="_blank"
                  rel="noopener nofollow"
                >
                  {b.siteUrl.replace(/^https?:\/\//, "")} →
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>{t("home.categoriesTitle")}</h2>
        <span class="count">{topCategories.length} {t("home.sections")}</span>
      </div>
      <ul class="cat-index">
        {
          topCategories.map((c, i) => (
            <li>
              <a href={catHref(c.slug)}>
                <span class="idx">{String(i + 1).padStart(2, "0")}</span>
                <span class="name">{catName(c, locale)}</span>
                <span class="count-n">{c.count}</span>
                <span class="arrow">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>
