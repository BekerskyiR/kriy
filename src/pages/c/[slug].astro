---
import Layout from "../../layouts/Layout.astro";
import ProductCard from "../../components/ProductCard.astro";
import {
  getCategories,
  getProductsByCategory,
  getBrandsInCategory,
  type GenderFilter,
} from "../../lib/catalog";

const { slug } = Astro.params;
const pageParam = Number(Astro.url.searchParams.get("page") ?? "1");
const page = Number.isFinite(pageParam) && pageParam > 0 ? Math.floor(pageParam) : 1;

const gParam = Astro.url.searchParams.get("g");
const gender: GenderFilter = gParam === "men" || gParam === "women" ? gParam : "all";

const categories = await getCategories();
const category = categories.find((c) => c.slug === slug);

if (!category) {
  return new Response(null, { status: 404, statusText: "Category not found" });
}

// brand facet + validate the requested brand against brands actually present
const brandFacets = await getBrandsInCategory(slug!, gender);
const brandParam = Astro.url.searchParams.get("brand");
const activeBrand = brandFacets.some((b) => b.slug === brandParam) ? brandParam! : undefined;

const { products, total, totalPages } = await getProductsByCategory(
  slug!,
  page,
  24,
  gender,
  activeBrand,
);
const nf = new Intl.NumberFormat("uk-UA");

// URL helpers preserve the other active filters
const gQuery = gender === "all" ? "" : `&g=${gender}`;
const brandQuery = activeBrand ? `&brand=${activeBrand}` : "";
const pageHref = (p: number) => `/c/${slug}?page=${p}${gQuery}${brandQuery}`;
// switching brand keeps gender but resets paging
const brandHref = (b?: string) => {
  const params = new URLSearchParams();
  if (gender !== "all") params.set("g", gender);
  if (b) params.set("brand", b);
  const qs = params.toString();
  return qs ? `/c/${slug}?${qs}` : `/c/${slug}`;
};
---

<Layout
  nav="catalog"
  gender={gender}
  title={`${category.nameUk} — КРІЙ`}
  description={`${category.nameUk}: товари українських брендів. ${nf.format(total)} позицій у наявності.`}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow"><a href="/">Каталог</a> / {category.nameUk}</span>
      <div class="section__head">
        <h2>{category.nameUk}</h2>
        <span class="count">{nf.format(total)} товарів</span>
      </div>

      {
        brandFacets.length > 1 && (
          <nav class="brand-filter" aria-label="Фільтр за брендом">
            <a
              href={brandHref()}
              class:list={["brand-chip", { active: !activeBrand }]}
              aria-current={!activeBrand ? "true" : undefined}
            >
              Усі бренди
            </a>
            {brandFacets.map((b) => (
              <a
                href={brandHref(b.slug)}
                class:list={["brand-chip", { active: activeBrand === b.slug }]}
                aria-current={activeBrand === b.slug ? "true" : undefined}
              >
                {b.name} <span class="brand-chip__n">{b.count}</span>
              </a>
            ))}
          </nav>
        )
      }

      {
        products.length > 0 ? (
          <div class="product-grid">
            {products.map((p) => (
              <ProductCard product={p} />
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <h3>Поки порожньо</h3>
            <p>
              {gender === "all"
                ? "У цій категорії ще немає товарів у наявності. Загляни в інші розділи або повернись пізніше — каталог оновлюється щодня."
                : "У цьому фільтрі поки немає товарів. Спробуй показати всі або іншу категорію."}
            </p>
            {gender === "all" ? (
              <a class="btn btn--ghost" href="/">← До категорій</a>
            ) : (
              <a class="btn btn--ghost" href={`/c/${slug}`}>Показати всі →</a>
            )}
          </div>
        )
      }

      {
        totalPages > 1 && (
          <nav class="pagination" aria-label="Сторінки">
            <a class={page <= 1 ? "disabled" : ""} href={pageHref(page - 1)} rel="prev">
              ← Назад
            </a>
            <span>
              {page} / {totalPages}
            </span>
            <a
              class={page >= totalPages ? "disabled" : ""}
              href={pageHref(page + 1)}
              rel="next"
            >
              Далі →
            </a>
          </nav>
        )
      }
    </div>
  </section>
</Layout>
