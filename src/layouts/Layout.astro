---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  nav?: "catalog" | "brands" | null;
}
const {
  title = "СВОЄ — каталог українських брендів одягу",
  description = "Вітрина українських брендів одягу. Обери категорію — знайди своє, купуй напряму в бренда.",
  nav = null,
} = Astro.props;
---

<!doctype html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="wordmark" href="/">СВО<span class="ye">Є</span></a>
        <nav class="site-nav" aria-label="Головна навігація">
          <a href="/" aria-current={nav === "catalog" ? "page" : undefined}>Каталог</a>
          <a href="/for-brands" aria-current={nav === "brands" ? "page" : undefined}
            >Для брендів</a
          >
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <div>
          <strong>СВОЄ</strong> — вітрина, а не магазин. Купівля відбувається на сайті бренда.
        </div>
        <div>
          <a href="/for-brands">Додати свій бренд →</a>
        </div>
      </div>
    </footer>
  </body>
</html>
