---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  nav?: "catalog" | "brands" | null;
  /** When set, renders the men/women/all strip under the header. */
  gender?: "all" | "men" | "women";
}
const {
  title = "КРІЙ — каталог українських брендів одягу",
  description = "Вітрина українських брендів одягу. Обери категорію — знайди свій крій, купуй напряму в бренда.",
  nav = null,
  gender,
} = Astro.props;

// gender switch keeps the current path, drops paging (a new gender = page 1)
const path = Astro.url.pathname;
const genderHref = (g: "all" | "men" | "women") => (g === "all" ? path : `${path}?g=${g}`);
const genderTabs: Array<{ key: "all" | "men" | "women"; label: string }> = [
  { key: "all", label: "Усі" },
  { key: "women", label: "Жіноче" },
  { key: "men", label: "Чоловіче" },
];
---

<!doctype html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="wordmark" href="/">КРІ<span class="ye">Й</span></a>
        <nav class="site-nav" aria-label="Головна навігація">
          <a href="/" aria-current={nav === "catalog" ? "page" : undefined}>Каталог</a>
          <a href="/for-brands" aria-current={nav === "brands" ? "page" : undefined}
            >Для брендів</a
          >
        </nav>
      </div>
    </header>

    {
      gender && (
        <div class="gender-strip">
          <div class="container gender-strip__inner">
            <span class="gender-strip__label">Показувати:</span>
            <nav class="gender-switch" aria-label="Стать">
              {genderTabs.map((t) => (
                <a
                  href={genderHref(t.key)}
                  class:list={["gender-switch__tab", { active: gender === t.key }]}
                  aria-current={gender === t.key ? "true" : undefined}
                >
                  {t.label}
                </a>
              ))}
            </nav>
          </div>
        </div>
      )
    }

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <div>
          <strong>КРІЙ</strong> — вітрина, а не магазин. Купівля відбувається на сайті бренда.
        </div>
        <div>
          <a href="/for-brands">Додати свій бренд →</a>
        </div>
      </div>
    </footer>
  </body>
</html>
