---
import { formatPrice, resolveImage, type Product } from "../lib/catalog";

interface Props {
  product: Product;
}
const { product } = Astro.props;
const img = resolveImage(product.mainImage, 500, 667);

// Outbound link to the brand's site with a UTM tag. The click goes through
// /out — a redirector that increments the brand's click counter and then
// sends the user to productUrl (see src/pages/out.ts).
const out = `/out?b=${encodeURIComponent(product.brandSlug)}&u=${encodeURIComponent(product.productUrl)}`;
---

<a class="tag-card" href={out} target="_blank" rel="noopener nofollow sponsored">
  <div class="tag-card__img">
    {
      img ? (
        <img src={img} alt={product.title} loading="lazy" width="500" height="667" />
      ) : null
    }
  </div>
  <div class="tag-card__body">
    <span class="tag-card__brand">{product.brandName}</span>
    <span class="tag-card__title">{product.title}</span>
    <span class="tag-card__price">{formatPrice(product.priceMinor, product.currency)}</span>
    <span class="tag-card__out">до бренда →</span>
  </div>
</a>
